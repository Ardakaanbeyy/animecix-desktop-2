# AnimeciX Desktop — Environment Variables
# Copy this file to .env and fill in your values.
# These are injected at build time by Vite (VITE_ prefix required).

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=https://your-api-domain.com

# CDN domain for video segments and file delivery (hostname only, no protocol)
VITE_CDN_DOMAIN=your-cdn-domain.com

# Main website URL (no trailing slash)
VITE_SITE_URL=https://your-site.com

# Discord application Client ID for Rich Presence (create at https://discord.com/developers)
VITE_DISCORD_CLIENT_ID=your-discord-client-id